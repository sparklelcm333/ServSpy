#: ../../Network_APIs/TCP_Server_APIs.rst:493 ec8be449dbe1480c88dffd6f3122b57b
msgid "``/clients``: prints the connected clients and their connection times."
msgstr "``/clients``：列印連線的客戶端及其連線時間。"

#: ../../Network_APIs/TCP_Server_APIs.rst:494 2b9307a16cd34c37ba22d668072d7597
msgid ""
